{
  "expo": {
    "name": "Haram Navigator",
    "slug": "haram-navigator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "haram-navigator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.haramnavigator",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nearest Haram gates from your location",
        "NSLocationAlwaysUsageDescription": "Navigate to Haram gates while walking"
      }
    },
    "android": {
      "package": "com.yourname.haramnavigator",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3F20"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E3F20"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find nearest Haram gates from your location",
          "locationAlwaysAndWhenInUsePermission": "Navigate to Haram gates while walking",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
